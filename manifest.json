{
  "manifest_version": 3,
  "name": "Copilot Usage Tracker",
  "version": "1.0.0",
  "description": "Real-time GitHub Copilot daily usage limit tracker for Microsoft Edge",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Copilot Usage Tracker"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content/injector.js"],
      "css": ["content/content-styles.css"],
      "run_at": "document_start"
    }
  ]
}
